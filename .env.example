# Supabase — create a project at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Server-side / CI only — never expose to the browser or mobile bundle
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web (Vite) — must be prefixed VITE_ to be exposed to the browser bundle
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mobile (Expo) — must be prefixed EXPO_PUBLIC_ to be bundled
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Expo — get a token at https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_TOKEN=your-expo-token

# Supabase — public read-only credentials, safe to bundle into the app
# Copy to .env.local and fill in your project values
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Expo publish token — CI only, never commit a real value
EXPO_TOKEN=your-expo-token

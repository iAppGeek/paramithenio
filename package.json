{
  "name": "aesop-fables",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": ">=0.8.13",
      "@types/react": "~19.0.0"
    }
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "keep-alive": "tsx scripts/keep-alive.ts",
    "add-story": "tsx scripts/add-story.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@supabase/supabase-js": "^2.108.2",
    "tsx": "^4",
    "turbo": "^2",
    "typescript": "^5"
  }
}
